generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  PARTICIPANT
  COMMISSIONER
  ADMIN
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  DISPUTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
}

enum TournamentCommissionerRole {
  LEAD
  ASSISTANT
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role     @default(PARTICIPANT)
  name      String?
  surname             String?
  phone     String?
  city      String?
  country             String?
  rating              Int      @default(1200)
  fideId              String?
  fideRating          Int?
  fideTitle           String?
  preferences         Json?
  onboardingCompleted Boolean  @default(false)
  emailOptOut         Boolean  @default(false)
  photoUrl            String?
  createdAt           DateTime @default(now())

  sessions                Session[]
  commissioner            Commissioner?
  memberships             Membership[]
  payments                Payment[]
  tournamentRegistrations TournamentRegistration[]
  uploadedPhotos          TournamentPhoto[]
  watchlist               TournamentWatchlist[]
  notifications           Notification[]
  tournamentResults       TournamentResult[]
  tournamentCommissioners TournamentCommissioner[]
  deviceTokens            DeviceToken[]
}

model OtpCode {
  id        String    @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Tournament {
  id              String           @id @default(cuid())
  title           String
  city            String
  country         String
  startDate       DateTime
  endDate         DateTime
  status          TournamentStatus @default(DRAFT)
  commissionerId  String
  commissioner    Commissioner     @relation(fields: [commissionerId], references: [id])
  maxParticipants Int?
  fee             Float?
  currency        String           @default("USD")
  description     String?
  ratingLimit     Int?
  timeControl     String?
  createdAt       DateTime         @default(now())

  registrations           TournamentRegistration[]
  payments                Payment[]
  photos                  TournamentPhoto[]
  watchlistedBy           TournamentWatchlist[]
  results                 TournamentResult[]
  announcements           Announcement[]
  schedule                ScheduleEntry[]
  rounds                  Round[]
  tournamentCommissioners TournamentCommissioner[]

  @@index([commissionerId])
  @@index([status])
}

model TournamentCommissioner {
  id           String                     @id @default(cuid())
  tournamentId String
  tournament   Tournament                 @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         TournamentCommissionerRole @default(ASSISTANT)
  assignedAt   DateTime                   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model TournamentRegistration {
  id           String             @id @default(cuid())
  tournamentId String
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       RegistrationStatus @default(PENDING)
  paymentId    String?            @unique
  payment      Payment?           @relation(fields: [paymentId], references: [id])
  createdAt    DateTime           @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model Commissioner {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio            String?
  specialization String?
  country        String?
  city           String?
  cities         String[]
  photoUrl       String?
  achievements   String?
  website        String?
  telegram       String?
  isVerified     Boolean  @default(false)

  tournaments Tournament[]

  @@index([isVerified, country])
}

model OrganizationRequest {
  id               String        @id @default(cuid())
  organizationName String
  contactName      String
  email            String
  phone            String?
  description      String?
  status           RequestStatus @default(PENDING)
  createdAt        DateTime      @default(now())
}

model Membership {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  status         MembershipStatus @default(ACTIVE)
  certificateUrl String?
  createdAt      DateTime         @default(now())

  @@index([userId])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId String?
  tournament   Tournament?   @relation(fields: [tournamentId], references: [id])
  amount       Float
  currency     String        @default("USD")
  status       PaymentStatus @default(PENDING)
  externalId   String?
  createdAt    DateTime      @default(now())

  registration TournamentRegistration?

  @@index([userId])
  @@index([tournamentId])
  @@index([externalId])
}

model TournamentPhoto {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  url          String
  caption      String?
  uploadedBy   String
  uploader     User       @relation(fields: [uploadedBy], references: [id])
  createdAt    DateTime   @default(now())

  @@index([tournamentId])
}

model TournamentWatchlist {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId])
  @@index([userId])
  @@index([tournamentId])
}

model TournamentResult {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  place        Int
  score        Float
  eloChange    Int
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "REGISTRATION_APPROVED" | "REGISTRATION_REJECTED" | "TOURNAMENT_OPEN" | "PAYMENT_CONFIRMED" | "PAYMENT_DISPUTED" | "SCHEDULE_UPDATED" | "TOURNAMENT_ANNOUNCEMENT" | "WATCHLIST_TOURNAMENT_OPEN" | "NEW_REGISTRATION"
  title     String
  body      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Announcement {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  title        String
  body         String
  published    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tournamentId])
}

model ScheduleEntry {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundNumber  Int?
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime?
  venue        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tournamentId])
}

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  processedAt   DateTime @default(now())
  eventType     String?
  status        String   @default("processed")
  errorMessage  String?
  rawRef        String?  // stores "eventId:eventType" for dead letter tracing
}

model Round {
  id           String    @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  roundNumber  Int
  status       String    @default("PENDING")
  pairings     Pairing[]
  createdAt    DateTime  @default(now())

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
}

model Pairing {
  id        String   @id @default(cuid())
  roundId   String
  round     Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player1Id String
  player2Id String?
  result    String?
  board     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
